# ===== Frontend (Vite) =====
# URL backend API для frontend (укажите ваш Render URL)
VITE_API_BASE_URL=https://smart-home-api-l5dr.onrender.com/api

# ===== Backend (Render) =====

# Порт сервера
PORT=7860

# Режим работы
NODE_ENV=production

# URL backend (укажите ваш Render URL после деплоя)
BACKEND_URL=https://smart-home-api-l5dr.onrender.com

# URL frontend
FRONTEND_URL=https://tox1k332.github.io/smart-home-app

# ===== База данных =====
# MongoDB Atlas connection string
# Format: mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGODB_URI=

# ===== Безопасность =====
# Случайная строка для JWT (минимум 32 символа)
JWT_SECRET=

# ===== Email (Resend) =====
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# ===== OAuth =====
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Weather API =====
# Open-Meteo - бесплатный API погоды (не требует ключа)
# https://open-meteo.com/en/docs
